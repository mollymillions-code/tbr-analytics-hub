# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to your deployment URL in production
# AUTH_URL=https://tbr-analytics-hub.vercel.app

# Gemini API — Canvas AI Analysis
GEMINI_API_KEY=

# Vercel Blob — Saved Reports Storage
# Create at: https://vercel.com/dashboard/stores → Create Blob Store
# Then link to project and copy the read-write token
BLOB_READ_WRITE_TOKEN=
